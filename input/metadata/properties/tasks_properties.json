{
  "tasks_properties": {
    "parallel_workers": {
      "type": "number",
      "description": "How many parallel workers should Task Manager use",
      "default": 1,
      "minimum": 1
    },
    "tasks": {
      "type": "array",
      "description": "The list of things that Task Manager should do in an unordered manner",
      "properties": {
        "type": "object",
        "task_type": {
          "type": "string",
          "pattern": "HERD_INITIALIZATION|SIMULATION_SIGNLE_RUN|SIMULATION_MULTI_RUN|SENSITIVITY_ANALYSIS|INPUT_DATA_VALIDATION|END_TO_END_TESTING|POST_PROCESSING"
        },
        "variable name style": {
          "type": "string",
          "pattern": "block|inline|verbose|basic",
          "description": "The formatting option for variable_names.txt file",
          "default": "basic"
        },
        "exclude_info_maps": {
          "type": "bool",
          "description": "Exclude info_maps from the output",
          "default": false
        },
        "init_herd": {
          "type": "bool",
          "description": "Select this flag if you want to initialize the herd by generating a herd population through simulation.",
          "default": false
        },
        "save_animals": {
          "type": "bool",
          "description": "Choose this flag if you want to save the generated herd data into a JSON file.",
          "default": false
        },        
        "save animals directory": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z]:\\)?(?:[a-zA-Z0-9._-]+[\\/])*$",
          "description": "The saving directory for animals if save_animals is set to true",
          "default": "output/"
        },        
        "output directory": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z]:\\)?(?:[a-zA-Z0-9._-]+[\\/])*$",
          "description": "The saving directory for output",
          "default": "output/"
        },
        "filters directory": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z]:\\)?(?:[a-zA-Z0-9._-]+[\\/])*$",
          "description": "The directory for the files containing the output filters",
          "default": "output/output_filters/"
        },
        "CSV directory": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z]:\\)?(?:[a-zA-Z0-9._-]+[\\/])*$",
          "description": "The directory for the csv output files to be saved",
          "default": "output/CSVs/"
        },
        "graphics directory": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z]:\\)?(?:[a-zA-Z0-9._-]+[\\/])*$",
          "description": "The saving directory for graphics",
          "default": "output/graphics/"
        },
        "output pool path": {
          "type": "string",
          "pattern": "^(?:[a-zA-Z]:[\\/])?(?:[a-zA-Z0-9._-]+[\\/])*(?:[a-zA-Z0-9._-]+\\.json)$",
          "description": "The path to a JSON files to load the Output Manager's pool from for post processing",
          "default": ""
        }
      }
    }
  }
}
