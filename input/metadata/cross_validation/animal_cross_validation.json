    {
      "description": "Sum of parity fractions must equal 1.0",
      "aliases": {
        "variables": {
          "p1": "animal.herd_information.parity_fractions.1",
          "p2": "animal.herd_information.parity_fractions.2",
          "p3": "animal.herd_information.parity_fractions.3",
          "p4": "animal.herd_information.parity_fractions.4",
          "p5": "animal.herd_information.parity_fractions.5"
        },
        "constants": {
          "one": 1.0
        }
      },
      "rules": [
        {
          "left_hand": {
            "aggregation": {
              "operation": "sum",
              "operands": ["p1", "p2", "p3", "p4", "p5"]
            }
          },
          "right_hand": {
            "aggregation": {
              "operation": "no_op",
              "operands": ["one"]
            }
          },
          "relationship": "equal"
        }
      ]
    },
