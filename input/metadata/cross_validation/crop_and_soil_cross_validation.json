    {
      "description": "All crop configurations: optimal_temperature must be greater than or equal to minimum_temperature",
      "aliases": {
        "variables": {
          "crop_configurations": "crop_configurations.crop_configurations"
        },
        "constants": {
          "true_constant": true
        }
      },
      "rules": [
        {
          "left_hand": {
            "for_each": {
              "mode": "enforce",
              "in": "crop_configurations",
              "field": "optimal_temperature",
              "field_to_compare": "minimum_temperature",
              "relationship": "greater_or_equal_to"
            }
          },
          "right_hand": {
            "aggregation": {
              "operation": "no_op",
              "mode": "element_wise",
              "operands": ["true_constant"]
            }
          },
          "relationship": "equal"
        }
      ]
    },
