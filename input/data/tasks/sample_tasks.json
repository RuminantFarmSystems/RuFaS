{
  "parallel_workers": 8,
  "tasks": [
    {
      "task_type": "SIMULATION_SINGLE_RUN",
      "metadata_file_path": "input/metadata/default_metadata.json",
      "output_prefix": "Task 1",
      "log_verbosity": "logs"
    },
    {
      "task_type": "INPUT_DATA_AUDITION",
      "metadata_file_path": "input/metadata/default_metadata.json",
      "output_prefix": "Task 2",
      "log_verbosity": "logs"
    },
    {
      "task_type": "SIMULATION_SINGLE_RUN",
      "metadata_file_path": "input/metadata/default_metadata.json",
      "output_prefix": "Task 3",
      "log_verbosity": "logs",
      "random_seed": 42
    },
    {
      "task_type": "SIMULATION_MULTI_RUN",
      "output_prefix": "Task 4",
      "log_verbosity": "logs",
      "random_seed": 42
    },
    {
      "task_type": "SENSITIVITY_ANALYSIS",
      "output_prefix": "Task 5",
      "log_verbosity": "logs",
      "sampler": "fractional_factorial",
      "SA_input_variables": [
        {
          "variable_name": "first var",
          "lower_bound": 1,
          "upper_bound": 100
        },
        {
          "variable_name": "second var",
          "lower_bound": -10,
          "upper_bound": 10
        },
        {
          "variable_name": "third var",
          "lower_bound": -100,
          "upper_bound": 100
        }
      ],
      "SA_load_balancing_start": 0.5,
      "SA_load_balancing_stop": 0.75
    }
  ]
}
