{
  "parallel_workers": 4,
  "tasks": [
    {
      "task_type": "SENSITIVITY_ANALYSIS",
      "metadata_file_path": "input/metadata/MSA_metadata.json",
      "output_prefix": "MSA",
      "log_verbosity": "none",
      "suppress_log_files": true,
      "random_seed": 42,
      "sampler": "sobol",
      "SA_load_balancing_start": 0,
      "SA_load_balancing_stop": 1,
      "export_input_data_to_csv": true,
      "properties_file_path": "input/metadata/properties/MSA_properties.json",
      "sampler_n": 8,
      "SA_input_variables": [
        {
          "variable_name": "manure_management.storage_0.NATURAL_LOG_ARRHENIUS_CONSTANT",
          "lower_bound": 29,
          "upper_bound": 32,
          "data_type":"float"
        },
        {
          "variable_name": "manure_management.storage_0.ANAEROBIC_LAGOON_MINIMUM_TEMPERATURE",
          "lower_bound": 0,
          "upper_bound": 2,
          "data_type":"float"
        }
      ]
    }
]
}