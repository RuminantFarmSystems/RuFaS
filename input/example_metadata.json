{
  "files": {
    "config": {
      "title": "Config Data",
      "description": "Configuration Information",
      "path": "config/example_config.json",
      "type": "json",
      "properties": "config_properties"
    },
    "animal": {
      "title": "Animal data",
      "description": "Moo Moo!",
      "path": "animal/example_animal.json",
      "type": "json",
      "properties": "animal_properties"
    },
    "crop": {
      "title": "Crop data",
      "description": "Alfafa is fun!",
      "path": "crop/example_rotation.json",
      "type": "json",
      "properties": "crop_properties"
    },
    "economy": {
      "title": "Economy data",
      "description": "Time is money!",
      "path": "EEE/example_costs.csv",
      "type": "csv",
      "properties": "economic_properties"
    },
    "emission": {
      "title": "Emissions data",
      "description": "Let's think about global warming",
      "path": "EEE/example_emissions.json",
      "type": "json",
      "properties": "emissions_properties"
    },
    "feed": {
      "title": "Feed data",
      "description": "Those cows need to eat!",
      "path": "feed/example_user_feeds.csv",
      "type": "csv",
      "properties": "feed_properties"
    },
    "manure": {
      "title": "Manure data",
      "description": "You thought it's a waste, but those crops need to eat as well",
      "path": "manure/example_manure_management.json",
      "type": "json",
      "properties": "manure_properties"
    },
    "soil": {
      "title": "Soil data",
      "description": "Stop treating soil like dirt!",
      "path": "soil/example_soil.json",
      "type": "json",
      "properties": "soil_properties"
    },
    "field_management": {
      "title": "Field Management Configuration",
      "description": "Fertilizer, manure, and tillage application schedules",
      "path": "field_management/example_field_management.json",
      "type": "json",
      "properties": "field_management_properties"
    },
    "weather": {
      "title": "Weather data",
      "description": "Let's turn on the AC",
      "path": "weather/example_weather.csv",
      "type": "csv",
      "properties": "weather_properties"
    }
  },
  "properties": {
    "config_properties": {
      "start_date": {
        "type": "string",
        "description": "The year and Julian day on which the simulation will start.",
        "pattern": "[12][019][0-9]{2}:(?:[1-9]|[1-9][0-9]|[12][0-9]{2}|3[0-5][0-9]|36[0-6])$",
        "default": "2009:1"
      },
      "end_date": {
        "type": "string",
        "description": "The year and Julian day on which the simulation will end.",
        "pattern": "[12][019][0-9]{2}:(?:[1-9]|[1-9][0-9]|[12][0-9]{2}|3[0-5][0-9]|36[0-6])$",
        "default": "2009:100"
      },
      "graphic_dir": {
        "type": "string",
        "description": "The location of the output graphics directory",
        "pattern": ".{1,50}",
        "default": "output/graphics/"
      },
      "output_dir": {
        "type": "string",
        "description": "The location of the output directory",
        "pattern": ".{1,50}",
        "default": "output/"
      },
      "random_seed": {
        "type": "number",
        "description": "The random seed",
        "minimum": 0,
        "default": 42
      },
      "simulate_animals": {
        "type": "boolean",
        "description": "Whether or not to simulate animals during the simulation",
        "default": true
      }
    },
    "animal_properties": {
      "calf_num": {
        "type": "number",
        "description": "The average number of pre-weaned calves (head)",
        "minimum": 0,
        "default": 8
      },
      "cow_num": {
        "type": "number",
        "description": "The number of dry and lactating cows (head)",
        "minimum": 0,
        "default": 100
      },
      "heiferI_num": {
        "type": "number",
        "description": "HeiferI is the number of youngstock post-weaning and before breeding (head)",
        "minimum": 0,
        "default": 44
      },
      "heiferII_num": {
        "type": "number",
        "description": "HeiferII is the number of heifers eligible for breeding and in early pregnancy (head)",
        "minimum": 0,
        "default": 38
      },
      "heiferIII_num_springers": {
        "type": "number",
        "description": "HeiferIII is the number of close-up heifers (head)",
        "minimum": 0,
        "default": 5
      },
      "herd_init": {
        "type": "boolean",
        "description": "Whether or not to initialize a herd if the milk prod and body weight numbers are exceedingly abnormal",
        "default": false
      },
      "herd_num": {
        "type": "number",
        "description": "The number of lactating and milking cows on farm (head)",
        "minimum": 0,
        "default": 187
      },
      "breed": {
        "type": "string",
        "description": "The predominant breed of the herd (Holstein - HO or Jersey - JE)",
        "default": "HO",
        "pattern": "[a-zA-Z]{2}"
      }
    },
    "crop_properties": {
       "crop_species": {
        "type": "string",
        "description": "the name of the crop being grown",
        "pattern": ".{a-z,A-Z,_}"
      },
      "harvest_days": {
        "type": "array",
        "description": "Julian day(s) of year to harvest",
        "minimum_length": 1
      },
      "harvest_years": {
        "type": "array",
        "description": "Calendar years in which the harvesting occurs",
        "minimum_length": 1
      },
      "harvest_operations": {
        "type": "array",
        "description": "Operation(s) with which this crop will be harvested.",
        "minimum_length": 1,
        "default": ["default"]
      },
      "harvest_type": {
        "type": "array",
        "description": "Whether the crop uses scheduled harvests or optimal harvests",
        "minimum_length": 1,
        "default": ["scheduled"]
      },
      "planting_days": {
        "type": "array",
        "description": "Julian day(s) of year to plant",
        "minimum_length": 1
      },
      "planting_years": {
        "type": "array",
        "description": "Calendar years in which the planting occurs",
        "minimum_length": 1
      },
      "pattern_repeat": {
        "type": "number",
        "description": "Number of times that this crop schedule should be repeated.",
        "minimum": 0,
        "default": 0
      },
      "pattern_skip": {
        "type": "number",
        "description": "Number of years to be skipped between schedule repetitions.",
        "minimum": 0,
        "default": 0
      }
    },
    "economic_properties": {
      "diesel_cost_gal": {
        "description": "cost of diesel per gallon",
        "type": "number",
        "minimum": 0,
        "default": 5.00
      },
      "electricity_cost_kwh": {
        "description": "cost of electricity per kwh",
        "type": "number",
        "minimum": 0,
        "default": 0.15
      },
      "natural_gas_cost_kwh": {
        "description": "cost of natural gas per kwh",
        "type": "number",
        "minimum": 0,
        "default": 0.053
      },
      "water_cost_gal": {
        "description": "cost of water per gallon",
        "type": "number",
        "minimum": 0,
        "default": 0.008
      }
    },
    "emissions_properties": {
      "alfalfa_tillage_emissions": {
        "type": "number",
        "description": "The amount of total tonnes CO2-eq generated from alfalfa tillage",
        "minimum": 0,
        "default": 500
      },
      "corn_grain_tillage_emissions": {
        "type": "number",
        "description": "The amount of total tonnes CO2-eq generated from corn grain tillage",
        "minimum": 0,
        "default": 300
      },
      "corn_silage_tillage_emissions": {
        "type": "number",
        "description": "The amount of total tonnes CO2-eq generated from corn silage tillage",
        "minimum": 0,
        "default": 400
      }
    },
    "feed_properties": {
      "description": {
        "description": "the description of the feed",
        "type": "string",
        "pattern": ".{2,50}"
      },
      "entry": {
        "description": "the entry number of the feed",
        "type": "number",
        "minimum": 1
      },
      "feed_name": {
        "description": "the name of the feed",
        "type": "string",
        "pattern": ".{2,50}"
      },
      "type": {
        "description": "the type of the feed",
        "type": "string",
        "pattern": ".{2,50}"
      },
      "units": {
        "description": "the unit the feed is measured in",
        "type": "string",
        "pattern": ".{2,10}",
        "default": "kg"
      }
    },
    "manure_properties": {},
    "soil_properties": {
      "n_mineralization": {
        "type": "number",
        "description": "The rate at which nitrogen is mineralized to nitrate (NO3)",
        "minimum": 0,
        "default": 1
      },
      "sand_content": {
        "type": "number",
        "description": "The average fraction of soil comprised of sand",
        "minimum": 0,
        "maximum": 1,
        "default": 0.08
      },
      "silt_content": {
        "type": "number",
        "description": "The average fraction of soil comprised of silt",
        "minimum": 0,
        "maximum": 1,
        "default": 0.1
      },
      "soil_albedo": {
        "type": "number",
        "description": "The fraction of light that is reflected by the soil surface",
        "minimum": 0,
        "maximum": 1,
        "default": 0.3
      }
    },
    "weather_properties": {
      "precip": {
        "description": "amount of precipitation",
        "type": "number",
        "minimum": 0,
        "default": 0
      }
    }
  },
  "cross-validation": {}
}

