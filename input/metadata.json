          "description": "Number of Calves, (head)",
          "type": "number",
          "default": 8,
          "minimum": 0
        },
        "heiferI_num": {
          "description": "The number of HeiferIs (youngstock post-weaning and before breeding), (head)",
          "type": "number",
          "default": 44,
          "minimum": 0
        },
        "heiferII_num": {
          "description": "The number of HeiferIIs (heifers eligible for breeding and in early pregnancy), (head)",
          "type": "number",
          "default": 38,
          "minimum": 0
        },
        "heiferIII_num_springers": {
          "description": "The number of HeiferIIIs (close-up heifers), (head)",
          "type": "number",
          "default": 5,
          "minimum": 0
        },
        "cow_num": {
          "description": "The number of dry and lactating cows, (head)",
          "type": "number",
          "default": 100,
          "minimum": 0
