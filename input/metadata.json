        "herd_init": {
          "description": "Initialize Herd or not",
          "type": "boolean"
        },
        "breed": {
          "description": "Breed (either Holstein or Jersey)",
          "type": "String",
          "default": "HO",
          "pattern": "^{HO|JE}$"
        }
      },
