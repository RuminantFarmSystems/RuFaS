  "properties": {
    "config_properties": {
      "start_date": {
        "type": "string",
        "description": "The year and Julian day on which the simulation will start.",
        "pattern": "[12][019][0-9]{2}:(?:[1-9]|[1-9][0-9]|[12][0-9]{2}|3[0-5][0-9]|36[0-6])$",
        "default": "2009:1"
      },
      "end_date": {
        "type": "string",
        "description": "The year and Julian day on which the simulation will end.",
        "pattern": "[12][019][0-9]{2}:(?:[1-9]|[1-9][0-9]|[12][0-9]{2}|3[0-5][0-9]|36[0-6])$",
        "default": "2009:100"
      },
      "graphic_dir": {
        "type": "string",
        "description": "The location of the output graphics directory",
        "pattern": ".{1,50}",
        "default": "output/graphics/"
      },
      "output_dir": {
        "type": "string",
        "description": "The location of the output directory",
        "pattern": ".{1,50}",
        "default": "output/"
      },
      "random_seed": {
        "type": "number",
        "description": "The random seed",
        "minimum": 0,
        "default": 42
      },
      "simulate_animals": {
        "type": "boolean",
        "description": "Whether or not to simulate animals during the simulation",
        "default": true
      }
    },
    "animal_properties": {
      "type": "object",
      "description": "Animal data",
      "herd_information": {
        "type": "object",
        "description": "Herd Demographics - An overview of the counts of different animal groups on the farm",
        "calf_num": {
          "description": "Number of Calves, (head)",
          "type": "number",
          "default": 8,
          "minimum": 0
        },
        "heiferI_num": {
          "description": "The number of HeiferIs (youngstock post-weaning and before breeding), (head)",
          "type": "number",
          "default": 44,
          "minimum": 0
        },
        "heiferII_num": {
          "description": "The number of HeiferIIs (heifers eligible for breeding and in early pregnancy), (head)",
          "type": "number",
          "default": 38,
          "minimum": 0
        },
        "heiferIII_num_springers": {
          "description": "The number of HeiferIIIs (close-up heifers), (head)",
          "type": "number",
          "default": 5,
          "minimum": 0
        },
        "cow_num": {
          "description": "The number of dry and lactating cows, (head)",
          "type": "number",
          "default": 100,
          "minimum": 0
        },
        "herd_num": {
          "description": "The number of lactating and milking cows on farm, (head)",
