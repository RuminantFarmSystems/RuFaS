{
    "multiple": [
      {
          "name": "Pen 3 number of milking cows",
          "filters": ["ManureHandlerDailyOutput_Pen_3_LAC_COW.num_animals"],
          "vertical_aggregation": "average",
          "slice_start": -365
      },
      {
        "name": "Pen 4 number of milking cows",
        "filters": ["ManureHandlerDailyOutput_Pen_4_LAC_COW.num_animals"],
        "vertical_aggregation": "average",
        "slice_start": -365
    },
      {
            "name": "Total number of milking cows in simulation",
            "cross_references":[
                "Pen 3 number of milking cows_ver_agg",
                "Pen 4 number of milking cows_ver_agg"
            ],
            "horizontal_aggregation": "sum"
      },
      {
          "name": "Whole herd daily milk production, kg",
          "filters": ["AnimalModuleReporter.report_life_cycle_manager_data.daily_milk_production"],
          "vertical_aggregation": "average",
          "slice_start": -365
      },
      {
          "name": "Whole herd daily milk production per cow, kg/cow",
          "cross_references":[
                "Whole herd daily milk production, kg_ver_agg",
                "Total number of milking cows in simulation_hor_agg"
            ],
          "horizontal_aggregation": "division"
      },



      {
          "name": "Daily DMI per cow, kg/cow",
          "filters": ["AnimalModuleReporter.report_ration_interval_data.ration_nutrient_amount_pen_3_LAC_COW"],
          "variables": ["dm"],
          "vertical_aggregation": "average",
          "slice_start": -365
      }, 
      {
          "name": "Daily CP intake per cow, kg/cow",
          "filters": ["AnimalModuleReporter.report_ration_interval_data.ration_nutrient_amount_pen_3_LAC_COW"],
          "variables": ["CP"],
          "vertical_aggregation": "average",
          "slice_start": -365
      },
      {
            "name": "Dietary CP, %",
            "cross_references":[
                "Daily CP intake per cow, kg/cow_CP_ver_agg",
                "Daily DMI per cow, kg/cow_dm_ver_agg"
            ],
            "constants": {
                "By 0.01": 0.01
            },
            "horizontal_aggregation": "division",
            "horizontal_order": [
                "Daily CP intake per cow, kg/cow_CP_ver_agg",
                "Daily DMI per cow, kg/cow_dm_ver_agg", 
                "By 0.01"
            ]
      },
        
      {
            "name": "Daily nitrogen intake per cow, kg/cow",
        "cross_references": ["Daily CP intake per cow, kg/cow_CP_ver_agg"],
        "variables": ["nitrogen"],
        "constants":{"N_content" : 0.16},
        "horizontal_aggregation": "product", 
        "horizontal_order":["Daily CP intake per cow, kg/cow_CP_ver_agg", "N_content"]
    },

     {
          "name": "Dietary nitrogen, %",
          "cross_references":[
              "Daily nitrogen intake per cow, kg/cow_hor_agg",
              "Daily DMI per cow, kg/cow_dm_ver_agg"
          ],
          "constants": {
              "By 0.01": 0.01
          },
          "horizontal_aggregation": "division",
          "horizontal_order": [
              "Daily nitrogen intake per cow, kg/cow_hor_agg",
              "Daily DMI per cow, kg/cow_dm_ver_agg", 
              "By 0.01"
          ]
    },
