    "#| label: tbl-an-nasem-prot-req-var\n",
    "#| tbl-cap: Key variables used in protein requirement calculations.\n",
    "import_table(\n",
    "  \"../resources/table_data/animal/tbl-an-nasem-prot-req-var.csv\",\n",
    "  colalign = [\"left\", \"left\", \"left\"]\n",
    "\n",
