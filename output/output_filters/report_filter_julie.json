{
  "multiple": [

      {
          "name": "Calves",
          "filters": ["AnimalModuleReporter.report_daily_animal_population.num_calves"],
          "vertical_aggregation": "average",
          "slice_start": -365
         },
      {
          "name": "Heifers",
          "filters": ["AnimalModuleReporter.report_daily_animal_population.num_(heiferIs|heiferIIs|heiferIIIs)"],
          "vertical_aggregation": "average",
          "horizontal_aggregation":"sum",
          "horizontal_first": true,
          "slice_start": -365
         },
         {
          "name": "Dry cows",
          "filters": ["AnimalModuleReporter.report_daily_animal_population.num_dry_cows"],
          "vertical_aggregation": "average",
          "slice_start": -365
         },
         {
          "name": "Milking cows",
          "filters": ["AnimalModuleReporter.report_daily_animal_population.num_lactating_cows"],
          "vertical_aggregation": "average",
          "slice_start": -365
         },
         {
          "name": "Total cows",
          "filters": [
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "vertical_aggregation": "average",
          "slice_start": -365
         },
         {
          "name": "# Growing",
          "filters": [
              "AnimalModuleReporter.report_daily_animal_population.num_(heiferIs|heiferIIs)"
          ],
          "vertical_aggregation": "average",
          "horizontal_aggregation": "sum",
          "slice_start": -365
         },
         {
          "name": "# Close-up",
          "filters": [
              "AnimalModuleReporter.report_daily_animal_population.num_(heiferIIIs|dry_cows)"
          ],
          "vertical_aggregation": "average",
          "horizontal_aggregation": "sum",
          "slice_start": -365
         },


         {
          "name": "% L1",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_1",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "horizontal_aggregation": "division",
          "vertical_aggregation": "average",
          "horizontal_first": true,
          "horizontal_order": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_1",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "slice_start": -365
         },
         {
          "name": "% L2",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_2",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "horizontal_aggregation": "division",
          "vertical_aggregation": "average",
          "horizontal_first": true,
          "horizontal_order": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_2",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "slice_start": -365
         },
         {
          "name": "% L3",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_3",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "horizontal_aggregation": "division",
          "vertical_aggregation": "average",
          "horizontal_first": true,
          "horizontal_order": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_3",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "slice_start": -365
         },
         {
          "name": "% L4+",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_greater_than_3",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "horizontal_aggregation": "division",
          "vertical_aggregation": "average",
          "horizontal_first": true,
          "horizontal_order": [
              "AnimalModuleReporter.report_life_cycle_manager_data.num_cow_for_parity_greater_than_3",
              "AnimalModuleReporter.report_daily_animal_population.num_cows_total"
          ],
          "slice_start": -365
         },
         {
          "name": "Total milk, kg",
          "filters": ["AnimalModuleReporter.report_life_cycle_manager_data.daily_milk_production"],
          "vertical_aggregation": "sum",
          "slice_start": -365
         },
         {
          "name": "Milk per cow/d, kg",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.daily_milk_production",
              "AnimalModuleReporter.report_daily_animal_population.num_lactating_cows"
          ],
          "horizontal_aggregation": "division",
          "horizontal_order": [
              "AnimalModuleReporter.report_life_cycle_manager_data.daily_milk_production",
              "AnimalModuleReporter.report_daily_animal_population.num_lactating_cows"
          ],
          "horizontal_first": true,
          "vertical_aggregation": "average",
          "slice_start": -365
         },
         {
          "name": "% milk fat",
          "filters": ["AnimalModuleReporter.report_life_cycle_manager_data.herd_milk_fat_percent"],
          "constants": {
              "By 100": 100
          },
          "vertical_aggregation": "average",
          "horizontal_aggregation": "division",
          "slice_start": -365
      },
      {
          "name": "% milk protein",
          "filters": ["AnimalModuleReporter.report_life_cycle_manager_data.herd_milk_protein_percent"],
          "constants": {
              "By 100": 100
          },
          "vertical_aggregation": "average",
          "horizontal_aggregation": "division",
          "slice_start": -365
      },
      {
          "name": "Milk fat, kg",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.herd_milk_fat_kg"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Milk protein, kg",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.herd_milk_protein_kg"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "weighted fat value",
          "cross_references": [
              "Milk fat, kg_ver_agg_(kg/day)"
          ],
          "constants": {
              "fat weight": 12.2
          },
          "horizontal_aggregation": "product"
      },
      {
          "name": "weighted protein value",
          "cross_references": [
              "Milk protein, kg_ver_agg_(kg/day)"
          ],
          "constants": {
              "protein weight": 7.7
          },
          "horizontal_aggregation": "product"
      },
      {
          "name": "weighted milk value",
          "cross_references": [
              "Total milk, kg_ver_agg_(kg/day)"
          ],
          "constants": {
              "milk weight": 0.25
          },
          "horizontal_aggregation": "product"
      },
      {
          "name": "Herd FPCM, kg",
          "cross_references": [
              "weighted fat value_hor_agg_(kg/day)",
              "weighted protein value_hor_agg_(kg/day)",
              "weighted milk value_hor_agg_(kg/day)"
          ],
          "horizontal_aggregation": "sum"
      },
      {
          "name": "Cow FPCM/d, kg",
          "cross_references":[
              "Herd FPCM, kg_hor_agg_(kg/day)",
              "Milking cows_ver_agg_(animals)"
          ],
          "constants": {
              "Days per year": 365
          },
          "horizontal_aggregation": "division",
          "horizontal_order": [
              "Herd FPCM, kg_hor_agg",
              "Milking cows_ver_agg",
              "Days per year"
          ]
      },
         {
          "name": "Calves sold",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.sold_calf_num"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Heifers sold repro culls",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.sold_heiferII_num"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Heifers sold oversupply",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.sold_heiferIII_oversupply_num"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Heifers sold",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.sold_(heiferII|heiferIII_oversupply)_num"
          ],
          "horizontal_aggregation": "sum",
          "vertical_aggregation": "sum",
          "slice_start": -365
      },

      {
          "name": "Cows sold",
          "filters": [
              "AnimalModuleReporter.report_sold_animal_information_sort_by_sell_day.sold_cows_sold_count"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Low production: cow sales",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.cull_reason_stats"
          ],
          "variables": ["culled for low production"],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Cow herd exits",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.cow_herd_exit_num"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Heifers bought",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.bought_heifer_num"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
         },
         {
          "name": "% herd turnover",
          "cross_references": [
              "Cow herd exits_ver_agg_(animals)",
              "Total cows_ver_agg_(animals)"
          ],
          "horizontal_aggregation": "division"
         },
         {
          "name": "Average age at first calving",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.avg_age_for_calving_1"
          ],
          "vertical_aggregation": "average",
          "slice_start": -365
      },
      {
          "name": "Calving interval",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.avg_calving_interval"
          ],
          "vertical_aggregation": "average", 
          "slice_start": -365
      },
      {
          "name": "Days open",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.calving_to_preg_time_.*"
          ],
          "vertical_aggregation": "average",
          "slice_start": -365
      },
      {
          "name": "AIs",
          "filters": [
              "AnimalModuleReporter.report_life_cycle_manager_data.ai_num.*"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Lact cow DMI, kg",
          "filters": [
              "AnimalModuleReporter.report_daily_ration.ration_daily_feed_totals_.*_LAC_COW"
          ],
          "variables": ["dry_matter_intake_total"],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Total herd DMI, kg",
          "filters": [
              "^AnimalModuleReporter.report_daily_ration.*"
          ],
          "variables": ["dry_matter_intake_total"],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Lact cow DMI/cow/d, kg",
          "cross_references": [
              "Lact cow DMI, kg_dry_matter_intake_total_ver_agg_(kg)",
              "Milking cows_ver_agg_(animals)"
          ],
          "constants": {
              "Days per year": 365
          },
          "horizontal_aggregation": "division",
          "horizontal_order": [
              "Lact cow DMI, kg_dry_matter_intake_total_ver_agg",
              "Milking cows_ver_agg",
              "Days per year"
          ]
      },
      {
          "name": "Total calf bw sold, kg",
          "filters": [
              "AnimalModuleReporter.report_sold_animal_information_sort_by_sell_day.sold_calves_sold_weight"
          ],
          "vertical_aggregation": "sum",
          "slice_start": -365
      },
      {
          "name": "Avg calf bw sold, kg",
          "cross_references": [
              "Total calf bw sold, kg_ver_agg_(kg)",
              "Calves sold_ver_agg_(animals)"
          ],
          "horizontal_aggregation": "division"
      },
          {
              "name": "Total heiferII bw sold, kg",
              "filters": [
                  "AnimalModuleReporter.report_sold_animal_information_sort_by_sell_day.heiferII_sold_weight"
              ],
              "vertical_aggregation": "sum",
              "slice_start": -365
          },
          {
              "name": "Avg heiferII bw sold, kg",
              "cross_references": [
                  "Total heiferII bw sold, kg_ver_agg_(kg)",
                  "Heifers sold repro culls_ver_agg_(animals)"
              ],
              "horizontal_aggregation": "division"
          }, 
          {
              "name": "Total heiferIII bw sold, kg",
              "filters": [
                  "AnimalModuleReporter.report_sold_animal_information_sort_by_sell_day.heiferIII_sold_weight"
              ],
              "vertical_aggregation": "sum",
              "slice_start": -365
          },  
          {
              "name": "Avg heiferIII bw sold, kg",
              "cross_references": [
                  "Total heiferIII bw sold, kg_ver_agg_(kg)",
                  "Heifers sold oversupply_ver_agg_(animals)"
              ],
              "horizontal_aggregation": "division"
          },   
          {
              "name": "Total cow bw sold, kg",
              "filters": [
                  "AnimalModuleReporter.report_sold_animal_information_sort_by_sell_day.sold_cows_sold_weight"
              ],
              "vertical_aggregation": "sum",
              "slice_start": -365
          },
          {
              "name": "Avg cow bw sold, kg",
              "cross_references": [
                  "Total cow bw sold, kg_ver_agg_(kg)",
                  "Cows sold_ver_agg_(animals)"
              ],
              "horizontal_aggregation": "division"
          },
          {
              "name": "Avg mature bodyweight, kg",
              "filters": [
                  "AnimalModuleReporter.report_life_cycle_manager_data.avg_mature_body_weight"
              ],
              "vertical_aggregation": "average",
              "slice_start": -365
          },
          {
              "name": "Total heiferIII bw bought, kg",
              "cross_references": [
                  "Heifers bought_ver_agg_(animals)",
                  "Avg mature bodyweight, kg_ver_agg_(kg)"
              ],
              "constants": {
                  "Percent MBW at calving": 0.82
              },
              "horizontal_aggregation": "product"
          },
          {
              "name": "Net heiferIII bw sold, kg",
              "cross_references": [
                  "Total heiferIII bw sold, kg_ver_agg_(kg)",
                  "Total heiferIII bw bought, kg_hor_agg_(animals*kg)"
              ],
              "horizontal_aggregation": "subtraction",
              "horizontal_order": [
                  "Total heiferIII bw sold, kg_ver_agg",
                  "Total heiferIII bw bought, kg_hor_agg"
              ]
          },
          {
              "name": "NE_g calves sold, MJ",
              "cross_references": [
                  "Total calf bw sold, kg_ver_agg_(kg)"
              ],
              "constants": {
                  "NE_g day old calf": 27.5
              },
              "horizontal_aggregation": "product"
          },
          {
              "name": "NE_g heiferIIs sold, MJ",
              "cross_references": [
                  "Total heiferII bw sold, kg_ver_agg_(kg)"
              ],
              "constants": {
                  "NE_g bred heifer": 11
              },
              "horizontal_aggregation": "product"
          },
          {
              "name": "NE_g NET heiferIIIs sold, MJ",
              "cross_references": [
                  "Net heiferIII bw sold, kg_hor_agg_(kg)"
              ],
              "constants": {
                  "NE_g bred heifer": 11
              },
              "horizontal_aggregation": "product"
          },
          {
              "name": "NE_g cows sold, MJ",
              "cross_references": [
                  "Total cow bw sold, kg_ver_agg_(kg)"
              ],
              "constants": {
                  "NE_g mature animal": 15
              },
              "horizontal_aggregation": "product"
          },
          {
              "name": "NE_g all meat sold, MJ",
              "cross_references": [
                  "NE_g calves sold, MJ_hor_agg_(kg)",
                  "NE_g heiferIIs sold, MJ_hor_agg_(kg)",
                  "NE_g NET heiferIIIs sold, MJ_hor_agg_(kg)",
                  "NE_g cows sold, MJ_hor_agg_(kg)"
              ],
              "horizontal_aggregation": "sum"
          },
          {
              "name": "NE_l all milk sold, MJ",
              "cross_references": [
                  "Herd FPCM, kg_hor_agg_(kg/day)"
              ],
              "constants": {
                  "NE_l FPCM": 3.1
              },
              "horizontal_aggregation": "product"
          },
          {
              "name": "total NE milk and meat",
              "cross_references": [
                  "NE_g all meat sold, MJ_hor_agg_(kg)",
                  "NE_l all milk sold, MJ_hor_agg_(kg/day)"
              ],
              "horizontal_aggregation": "sum"
          },
          {
              "name": "milk allocation factor",
              "cross_references": [
                  "NE_l all milk sold, MJ_hor_agg_(kg/day)",
                  "total NE milk and meat_hor_agg_(kg)"
              ],
              "horizontal_aggregation": "division",
              "horizontal_order":  [
                  "NE_l all milk sold, MJ_hor_agg",
                  "total NE milk and meat_hor_agg"
              ]
          },
          {
              "name": "Total housing methane, kg",
              "filters": [
                  "^ManureHandlerDailyOutput_Pen_.*housing_methane"
              ],
              "vertical_aggregation": "sum",
              "horizontal_aggregation": "sum",
              "horizontal_first": false,
              "slice_start": -365
          },
          {
              "name": "Total housing ammonia, kg",
              "filters": [
                  "^ManureHandlerDailyOutput_Pen_.*housing_ammonia"
              ],
              "vertical_aggregation": "sum",
              "horizontal_aggregation": "sum",
              "horizontal_first": false,
              "slice_start": -365
          },
          {
              "name": "Total storage methane, kg",
              "filters": [
                  "^ManureTreatmentDailyOutput_Pen_.*storage_methane"
              ],
              "vertical_aggregation": "sum",
              "horizontal_aggregation": "sum",
              "horizontal_first": false,
              "slice_start": -365
          },
          {
              "name": "Total storage ammonia, kg",
              "filters": [
                  "^ManureTreatmentDailyOutput_Pen_.*storage_ammonia"
              ],
              "vertical_aggregation": "sum",
              "horizontal_aggregation": "sum",
              "horizontal_first": false,
              "slice_start": -365
          },
          {
              "name": "Total manure methane, kg",
              "cross_references": [
                  "Total housing methane, kg_ver_hor_agg_(kg)",
                  "Total storage methane, kg_ver_hor_agg_(kg)"
              ],
              "horizontal_aggregation": "sum"
          },
          {
              "name": "Total manure ammonia, kg",
              "cross_references": [
                  "Total housing ammonia, kg_ver_hor_agg_(kg)",
                  "Total storage ammonia, kg_ver_hor_agg_(kg)"
              ],
              "horizontal_aggregation": "sum"
          },
          {
              "name": "Total manure nitrous oxide (storage), kg",
              "filters": [
                  "^ManureTreatmentDailyOutput_Pen_.*storage_nitrous_oxide.*"
              ],
              "vertical_aggregation": "sum",
              "horizontal_aggregation": "sum",
              "horizontal_first": false,
              "slice_start": -365
          },
          {
              "name": "Total manure biogas, kg",
              "filters": [
                  "^ManureTreatmentDailyOutput_Pen_.*biogas$"
              ],
              "vertical_aggregation": "sum",
              "horizontal_aggregation": "sum",
              "horizontal_first": false,
              "slice_start": -365
          },
          {
              "name": "Byproducts fed, kg DM",
              "filters": [
                  "AnimalModuleReporter.report_daily_ration.ration_daily_feed_totals.*"
              ],
              "variables": ["byproducts_total"],
              "vertical_aggregation": "sum",
              "slice_start": -365
          },
          {
              "name": "Byproducts fed, % of DM",
              "cross_references": [
                  "Byproducts fed, kg DM_byproducts_total_ver_agg_(kg)",
                  "Total herd DMI, kg_dry_matter_intake_total_ver_agg_(kg)"
              ],
              "horizontal_aggregation": "division",
              "horizontal_order":[
                  "Byproducts fed, kg DM_byproducts_total_ver_agg",
                  "Total herd DMI, kg_dry_matter_intake_total_ver_agg"
              ]
          },
      {
          "name": "CALF enteric methane, kg",
          "filters": [
              "AnimalModuleInputToManureModule_Pen_.*_CALF.enteric_methane_kg"
          ],
          "vertical_aggregation": "sum",
          "horizontal_aggregation": "sum",
          "horizontal_first": false,
          "slice_start": -365
      },
      {
          "name": "GROWING enteric methane, kg",
          "filters": [
              "AnimalModuleInputToManureModule_Pen_.*_GROWING.enteric_methane_kg"
          ],
          "vertical_aggregation": "sum",
          "horizontal_aggregation": "sum",
          "horizontal_first": false,
          "slice_start": -365
      },
      {
          "name": "CLOSE-UP enteric methane, kg",
          "filters": [
              "AnimalModuleInputToManureModule_Pen_.*_CLOSE_UP.enteric_methane_kg"
          ],
          "vertical_aggregation": "sum",
          "horizontal_aggregation": "sum",
          "horizontal_first": false,
          "slice_start": -365
      },
      {
          "name": "LAC-COW enteric methane, kg",
          "filters": [
              "AnimalModuleInputToManureModule_Pen_.*_LAC_COW.enteric_methane_kg"
          ],
          "vertical_aggregation": "sum",
          "horizontal_aggregation": "sum",
          "horizontal_first": false,
          "slice_start": -365
      },
      {
          "name":"Lact cow enteric methane kg/cow/d",
          "cross_references": [
              "LAC-COW enteric methane, kg_ver_hor_agg_(kg/day)",
              "Milking cows_ver_agg_(animals)"
          ],
          "constants": {
              "days per year": 365
          },
          "horizontal_aggregation": "division",
          "horizontal_order": [
              "LAC-COW enteric methane, kg_ver_hor_agg",
              "Milking cows_ver_agg",
              "days per year"
          ]
      },
      {
          "name": "total herd enteric methane, kg",
          "filters": [
              "AnimalModuleInputToManureModule_Pen_.*.enteric_methane_kg"
          ],
          "vertical_aggregation": "sum",
          "horizontal_aggregation": "sum",
          "horizontal_first": false,
          "slice_start": -365
      },
      {
          "name": "Herd enteric CH4 per FPCM, kg/kg",
          "cross_references": [
              "total herd enteric methane, kg_ver_hor_agg_(kg/day)",
              "Herd FPCM, kg_hor_agg_(kg/day)"
          ],
          "horizontal_aggregation": "division",
          "horizontal_order": [
              "total herd enteric methane, kg_ver_hor_agg",
              "Herd FPCM, kg_hor_agg"
          ]
      },
      {
          "name": "adjusted whole herd enteric methane, kg",
          "cross_references": [
              "total herd enteric methane, kg_ver_hor_agg_(kg/day)",
              "milk allocation factor_hor_agg_(kg^2/day)"
          ],
          "horizontal_aggregation": "product"
      },
      {
          "name": "adjusted herd enteric CH4 per FPCM, kg/kg",
          "cross_references": [
              "adjusted whole herd enteric methane, kg_hor_agg_(kg^3/day^2)",
              "Herd FPCM, kg_hor_agg_(kg/day)"
          ],
          "horizontal_aggregation": "division"
      },
      {
          "name": "Manure methane, calves, kg",
          "filters": [
              "^ManureHandlerDailyOutput_Pen_.*_CALF.housing_methane",
              "^ManureTreatmentDailyOutput_Pen_.*_CALF.storage_methane"
          ],
          "vertical_aggregation": "sum",
          "horizontal_aggregation": "sum",
          "horizontal_first": false,
          "slice_start": -365
      },
      {
          "name": "Manure methane, growing heifers, kg",
          "filters": [
              "^ManureHandlerDailyOutput_Pen_.*_GROWING.housing_methane",
              "^ManureTreatmentDailyOutput_Pen_.*_GROWING.storage_methane"
          ],
          "vertical_aggregation": "sum",
          "horizontal_aggregation": "sum",
          "horizontal_first": false,
          "slice_start": -365
      },
      {
          "name": "Manure methane, close-ups, kg",
          "filters": [
