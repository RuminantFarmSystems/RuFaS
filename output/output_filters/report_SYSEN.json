{
  "multiple": [
    {
      "name": "Calves",
      "filters": [
        "AnimalManager.daily_updates.num_calves"
      ],
      "vertical_aggregation": "average",
      "slice_start": -365
    },
    {
      "name": "Heifers",
      "filters": [
        "AnimalManager.daily_updates.num_(heiferIs|heiferIIs|heiferIIIs)"
      ],
      "vertical_aggregation": "average",
      "horizontal_aggregation": "sum",
      "horizontal_first": true,
      "slice_start": -365
    },
    {
      "name": "Dry cows",
      "filters": [
        "AnimalManager.daily_updates.num_dry_cows"
      ],
      "vertical_aggregation": "average",
      "slice_start": -365
    },
    {
      "name": "Milking cows",
      "filters": [
        "AnimalManager.daily_updates.num_lactating_cows"
      ],
      "vertical_aggregation": "average",
      "slice_start": -365
    },
    {
      "name": "Total cows",
      "filters": [
        "AnimalManager.daily_updates.num_cows_total"
      ],
      "vertical_aggregation": "average",
      "slice_start": -365
    },
    {
      "name": "% L1",
      "filters": [
        "LifeCycleManager.daily_update.num_cow_for_parity_1",
        "AnimalManager.daily_updates.num_cows_total"
      ],
      "horizontal_aggregation": "division",
      "vertical_aggregation": "average",
      "horizontal_first": "true",
      "horizontal_order": [
        "LifeCycleManager.daily_update.num_cow_for_parity_1",
        "AnimalManager.daily_updates.num_cows_total"
      ],
      "slice_start": -365
    },
    {
      "name": "% L2",
      "filters": [
        "LifeCycleManager.daily_update.num_cow_for_parity_2",
        "AnimalManager.daily_updates.num_cows_total"
      ],
      "horizontal_aggregation": "division",
      "vertical_aggregation": "average",
      "horizontal_first": "true",
      "horizontal_order": [
        "LifeCycleManager.daily_update.num_cow_for_parity_2",
        "AnimalManager.daily_updates.num_cows_total"
      ],
      "slice_start": -365
    },
    {
      "name": "% L3",
      "filters": [
        "LifeCycleManager.daily_update.num_cow_for_parity_3",
        "AnimalManager.daily_updates.num_cows_total"
      ],
      "horizontal_aggregation": "division",
      "vertical_aggregation": "average",
      "horizontal_first": "true",
      "horizontal_order": [
        "LifeCycleManager.daily_update.num_cow_for_parity_3",
        "AnimalManager.daily_updates.num_cows_total"
      ],
      "slice_start": -365
    },
    {
      "name": "% L4+",
      "filters": [
        "LifeCycleManager.daily_update.num_cow_for_parity_greater_than_3",
        "AnimalManager.daily_updates.num_cows_total"
      ],
      "horizontal_aggregation": "division",
      "vertical_aggregation": "average",
      "horizontal_first": "true",
      "horizontal_order": [
        "LifeCycleManager.daily_update.num_cow_for_parity_greater_than_3",
        "AnimalManager.daily_updates.num_cows_total"
      ],
      "slice_start": -365
    },
    {
      "name": "Total milk, kg",
      "filters": [
        "LifeCycleManager.daily_update.daily_milk_production"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Milk per cow/d, kg",
      "filters": [
        "LifeCycleManager.daily_update.daily_milk_production",
        "LifeCycleManager.daily_update.milking_cow_num"
      ],
      "horizontal_aggregation": "division",
      "horizontal_order": [
        "LifeCycleManager.daily_update.daily_milk_production",
        "LifeCycleManager.daily_update.milking_cow_num"
      ],
      "horizontal_first": "true",
      "vertical_aggregation": "average",
      "slice_start": -365
    },
    {
      "name": "% milk fat",
      "filters": [
        "LifeCycleManager.daily_update.herd_milk_fat_percent"
      ],
      "constants": {
        "By 100": 100
      },
      "vertical_aggregation": "average",
      "horizontal_aggregation": "division",
      "slice_start": -365
    },
    {
      "name": "% milk protein",
      "filters": [
        "LifeCycleManager.daily_update.herd_milk_protein_percent"
      ],
      "constants": {
        "By 100": 100
      },
      "vertical_aggregation": "average",
      "horizontal_aggregation": "division",
      "slice_start": -365
    },
    {
      "name": "Milk fat, kg",
      "cross_references": [
        "Total milk, kg_ver_agg",
        "% milk fat_hor_ver_agg"
      ],
      "horizontal_aggregation": "product"
    },
    {
      "name": "Milk protein, kg",
      "cross_references": [
        "Total milk, kg_ver_agg",
        "% milk protein_hor_ver_agg"
      ],
      "horizontal_aggregation": "product"
    },
    {
      "name": "weighted fat value",
      "cross_references": [
        "Milk fat, kg_hor_agg"
      ],
      "constants": {
        "fat weight": 12.2
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "weighted fat value ECM",
      "cross_references": [
        "Milk fat, kg_hor_agg"
      ],
      "constants": {
        "fat weight": 12.95
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "weighted protein value",
      "cross_references": [
        "Milk protein, kg_hor_agg"
      ],
      "constants": {
        "protein weight": 7.7
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "weighted protein value ECM",
      "cross_references": [
        "Milk protein, kg_hor_agg"
      ],
      "constants": {
        "protein weight": 7.2
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "weighted milk value",
      "cross_references": [
        "Total milk, kg_ver_agg"
      ],
      "constants": {
        "milk weight": 0.35
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "weighted milk value ECM",
      "cross_references": [
        "Total milk, kg_ver_agg"
      ],
      "constants": {
        "milk weight": 0.327
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "Herd FPCM, kg",
      "cross_references": [
        "weighted fat value_hor_agg",
        "weighted protein value_hor_agg",
        "weighted milk value_hor_agg"
      ],
      "horizontal_aggregation": "sum"
    },
    {
      "name": "Herd ECM, kg",
      "cross_references": [
        "weighted fat value ECM_hor_agg",
        "weighted protein value ECM_hor_agg",
        "weighted milk value ECM_hor_agg"
      ],
      "horizontal_aggregation": "sum"
    },
    {
      "name": "Cow FPCM/d, kg",
      "cross_references": [
        "Herd FPCM, kg_hor_agg",
        "Milking cows_ver_agg"
      ],
      "constants": {
        "Days per year": 365
      },
      "horizontal_aggregation": "division",
      "horizontal_order": [
        "Herd FPCM, kg_hor_agg",
        "Milking cows_ver_agg",
        "Days per year"
      ]
    },
    {
      "name": "Cow ECM/d, kg",
      "cross_references": [
        "Herd ECM, kg_hor_agg",
        "Milking cows_ver_agg"
      ],
      "constants": {
        "Days per year": 365
      },
      "horizontal_aggregation": "division",
      "horizontal_order": [
        "Herd ECM, kg_hor_agg",
        "Milking cows_ver_agg",
        "Days per year"
      ]
    },
    {
      "name": "Calf DMI, kg",
      "filters": [
        "^AnimalModuleReporter.*CALF.*"
      ],
      "variables": [
        "dry_matter_intake_total"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Heifer DMI, kg",
      "filters": [
        "^AnimalModuleReporter.*GROWING*"
      ],
      "variables": [
        "dry_matter_intake_total"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Dry cow DMI, kg",
      "filters": [
        "^AnimalModuleReporter.*CLOSE_UP*"
      ],
      "variables": [
        "dry_matter_intake_total"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Lact cow DMI, kg",
      "filters": [
        "AnimalModuleReporter.report_daily_ration.ration_daily_feed_totals_for_pen_.*_LAC_COW"
      ],
      "variables": [
        "dry_matter_intake_total"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Feed efficiency",
      "cross_references": [
        "Herd ECM, kg_hor_agg",
        "Lact cow DMI, kg_dry_matter_intake_total_ver_agg"
      ],
      "horizontal_aggregation": "division",
      "slice_start": -365
    },
    {
      "name": "Total herd DMI, kg",
      "filters": [
        "^AnimalModuleReporter.report_daily_ration.*"
      ],
      "variables": [
        "dry_matter_intake_total"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Lact cow DMI/cow/d, kg",
      "cross_references": [
        "Lact cow DMI, kg_dry_matter_intake_total_ver_agg",
        "Milking cows_ver_agg"
      ],
      "constants": {
        "Days per year": 365
      },
      "horizontal_aggregation": "division",
      "horizontal_order": [
        "Lact cow DMI, kg_dry_matter_intake_total_ver_agg",
        "Milking cows_ver_agg",
        "Days per year"
      ]
    },
    {
      "name": "Calf enteric methane, g",
      "filters": [
        "AnimalManager.daily_updates.daily_aggregate_calf_enteric_methane_g"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Heifer enteric methane, g",
      "filters": [
        "AnimalManager.daily_updates.daily_aggregate_heifer_enteric_methane_g"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Dry cow enteric methane, g",
      "filters": [
        "AnimalManager.daily_updates.daily_aggregate_dry_cow_enteric_methane_g"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Lact cow enteric methane, g",
      "filters": [
        "AnimalManager.daily_updates.daily_aggregate_lactating_cow_enteric_methane_g"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Lact cow enteric methane, kg",
      "cross_references": [
        "Lact cow enteric methane, g_ver_agg"
      ],
      "constants": {
        "by 0.001": 0.001
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "Lact cow enteric methane CO2eq, kg",
      "cross_references": [
        "Lact cow enteric methane, g_ver_agg"
      ],
      "constants": {
        "CH4 GWP": 29.8,
        "by 0.001": 0.001
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "Total enteric methane, g",
      "filters": [
        "AnimalManager.daily_updates.daily_aggregate_(calf|heifer|dry_cow|lactating_cow)_enteric_methane_g"
      ],
      "vertical_aggregation": "sum",
      "horizontal_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Total enteric methane, kg",
      "cross_references": [
        "Total enteric methane, g_hor_ver_agg"
      ],
      "constants": {
        "by 0.001": 0.001
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "Total enteric methane CO2eq, kg",
      "cross_references": [
        "Total enteric methane, g_hor_ver_agg"
      ],
      "constants": {
        "CH4 GWP": 29.8,
        "by 0.001": 0.001
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "Lact cow purchased feed emissions, kg",
      "filters": [
        "^AnimalModuleReporter.*LAC_COW*"
      ],
      "variables": [
        "feed_emissions_total"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Total purchased feed emissions, kg",
      "filters": [
        "AnimalModuleReporter.report_daily_feed_emissions.*"
      ],
      "variables": [
        "feed_emissions_total"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Total housing methane, kg",
      "filters": [
        "ManureHandlerDailyOutput_Pen_.*housing_methane"
      ],
      "vertical_aggregation": "sum",
      "horizontal_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Total housing methane CO2eq, kg",
      "cross_references": [
        "Total housing methane, kg_hor_ver_agg"
      ],
      "constants": {
        "CH4 GWP": 29.8
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "Total housing ammonia, kg",
      "filters": [
        "ManureHandlerDailyOutput_Pen_.*housing_ammonia"
      ],
      "vertical_aggregation": "sum",
      "horizontal_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Total storage methane, kg",
      "filters": [
        "^(?:AnaerobicDigestion_)?ManureTreatmentDailyOutput_Pen_.*storage_methane$"
      ],
      "vertical_aggregation": "sum",
      "horizontal_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Total storage methane CO2eq, kg",
      "cross_references": [
        "Total storage methane, kg_hor_ver_agg"
      ],
      "constants": {
        "CH4 GWP": 29.8
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "Total methane, kg",
      "cross_references": [
        "Total enteric methane, kg_hor_agg",
        "Total housing methane, kg_hor_ver_agg",
        "Total storage methane, kg_hor_ver_agg"
      ],
      "horizontal_aggregation": "sum"
    },
    {
      "name": "Total methane CO2eq, kg",
      "cross_references": [
        "Total methane, kg_hor_agg"
      ],
      "constants": {
        "CH4 GWP": 29.8
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "Total storage ammonia, kg",
      "filters": [
        "ManureTreatmentDailyOutput_Pen_.*storage_ammonia"
      ],
      "vertical_aggregation": "sum",
      "horizontal_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Total storage nitrous oxide, kg",
      "filters": [
        "ManureTreatmentDailyOutput_Pen_.*storage_nitrous_oxide.*"
      ],
      "vertical_aggregation": "sum",
      "horizontal_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Total storage nitrous oxide CO2eq, kg",
      "cross_references": [
        "Total storage nitrous oxide, kg_hor_ver_agg"
      ],
      "constants": {
        "N2O GWP": 273
      },
      "horizontal_aggregation": "product"
    },
    {
      "name": "Total storage biogas, kg",
      "filters": [
        "ManureTreatmentDailyOutput_Pen_.*biogas$"
      ],
      "vertical_aggregation": "sum",
      "horizontal_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Lact cow manure nitrogen, kg",
      "filters": [
        "AnimalManager.daily_updates.daily_aggregate_lactating_cow_manure_nitrogen"
      ],
      "vertical_aggregation": "sum",
      "slice_start": -365
    },
    {
      "name": "Total manure nitrogen, kg",
      "filters": [
        "AnimalManager.daily_updates.daily_aggregate_(calf|heifer|dry_cow|lactating_cow)_manure_nitrogen"
      ],
      "vertical_aggregation": "sum",
      "horizontal_aggregation": "sum",
      "slice_start": -365
    }
  ]
}