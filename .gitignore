# RUFAS .gitignore

# ignore text files
*.txt
*.txt#
!requirements.txt
*.doc
*.docx

# ignore log files
*.log
# ignore linear programming files
*.lp

# ignore python compiled files
*.pyc

# folders
build
others

# Ignore contents of Outputs directory, except for .keep file
# This is because we want to keep the Outputs direcectory, and git
# only stores non-empty directories
Outputs/*
!Outputs/.keep

# ignore project files
*.sublime-project
*.sublime-workspace
*.project
*.pydevproject
*.vscode
*.settings
.idea/**
