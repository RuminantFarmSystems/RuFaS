          },
          "N": {
            "title": "N",
            "type": "number",
            "options": {
              "grid_columns": 12,
              "inputAttributes": {
                "class": "text-primary form-control"
              },
              "infoText": "Fraction of nitrogen contained in the fertilizer mix by mass."
