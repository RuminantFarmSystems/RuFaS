{
  "title": "config_properties",
  "type": "object",
  "format": "grid",
  "properties": {
    "start_date": {
      "title": "start_date",
      "type": "boolean",
      "options": {
        "grid_columns": 12,
        "format": "select2",
        "inputAttributes": {
          "class": "text-primary form-control"
        },
        "infoText": "The year and Julian day on which the simulation will start."
      },
      "default": "2009:1"
    },
    "end_date": {
      "title": "end_date",
      "type": "boolean",
      "options": {
        "grid_columns": 12,
        "format": "select2",
        "inputAttributes": {
          "class": "text-primary form-control"
        },
        "infoText": "The year and Julian day on which the simulation will end."
      },
      "default": "2009:100"
    },
    "random_seed": {
      "title": "random_seed",
      "type": "number",
      "options": {
        "grid_columns": 12,
        "inputAttributes": {
          "class": "text-primary form-control"
        },
        "infoText": "The random seed"
      },
      "minimum": 0,
      "default": 42
    },
    "set_seed": {
      "title": "set_seed",
      "type": "boolean",
      "options": {
        "grid_columns": 12,
        "format": "select2",
        "inputAttributes": {
          "class": "text-primary form-control"
        },
        "infoText": "Whether or not to set random seed"
      },
      "default": true
    },
    "simulate_animals": {
      "title": "simulate_animals",
      "type": "boolean",
      "options": {
        "grid_columns": 12,
        "format": "select2",
        "inputAttributes": {
          "class": "text-primary form-control"
        },
        "infoText": "Whether or not to simulate animals during the simulation"
      },
      "default": true
    },
    "nutrient_standard": {
      "title": "nutrient_standard",
      "type": "boolean",
      "options": {
        "grid_columns": 12,
        "format": "select2",
        "inputAttributes": {
          "class": "text-primary form-control"
        },
        "infoText": "The nutrient standard to use for feed."
      },
      "default": "NASEM"
    }
  }
}