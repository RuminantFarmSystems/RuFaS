{
    "multiple": [
        {
            "name": "Calves",
            "filters": ["AnimalManager.daily_updates.num_calves"],
            "vertical_aggregation": "average",
            "slice_start": -365
           },
        {
            "name": "Heifers",
            "filters": ["AnimalManager.daily_updates.num_(heiferIs|heiferIIs|heiferIIIs)"],
            "vertical_aggregation": "average",
            "horizontal_aggregation":"sum",
            "horizontal_first": true,
            "slice_start": -365
           },
           {
            "name": "Dry cows",
            "filters": ["AnimalManager.daily_updates.num_dry_cows"],
            "vertical_aggregation": "average",
            "slice_start": -365
           },
           {
            "name": "Milking cows",
            "filters": ["AnimalManager.daily_updates.num_lactating_cows"],
            "vertical_aggregation": "average",
            "slice_start": -365
           },
           {
            "name": "Total cows",
            "filters": [
                "AnimalManager.daily_updates.num_cows_total"
            ],
            "vertical_aggregation": "average",
            "slice_start": -365
           },
           {
            "name": "% L1",
            "filters": [
                "LifeCycleManager.daily_update.num_cow_for_parity_1",
                "AnimalManager.daily_updates.num_cows_total"
            ],
            "horizontal_aggregation": "division",
            "vertical_aggregation": "average",
            "horizontal_first": "true",
            "horizontal_order": [
                "LifeCycleManager.daily_update.num_cow_for_parity_1",
                "AnimalManager.daily_updates.num_cows_total"
            ],
            "slice_start": -365
           },
           {
            "name": "% L2",
            "filters": [
                "LifeCycleManager.daily_update.num_cow_for_parity_2",
                "AnimalManager.daily_updates.num_cows_total"
            ],
            "horizontal_aggregation": "division",
            "vertical_aggregation": "average",
            "horizontal_first": "true",
            "horizontal_order": [
                "LifeCycleManager.daily_update.num_cow_for_parity_2",
                "AnimalManager.daily_updates.num_cows_total"
            ],
            "slice_start": -365
           },
           {
            "name": "% L3",
            "filters": [
                "LifeCycleManager.daily_update.num_cow_for_parity_3",
                "AnimalManager.daily_updates.num_cows_total"
            ],
            "horizontal_aggregation": "division",
            "vertical_aggregation": "average",
            "horizontal_first": "true",
            "horizontal_order": [
                "LifeCycleManager.daily_update.num_cow_for_parity_3",
                "AnimalManager.daily_updates.num_cows_total"
            ],
            "slice_start": -365
           },
           {
            "name": "% L4+",
            "filters": [
                "LifeCycleManager.daily_update.num_cow_for_parity_greater_than_3",
                "AnimalManager.daily_updates.num_cows_total"
            ],
            "horizontal_aggregation": "division",
            "vertical_aggregation": "average",
            "horizontal_first": "true",
            "horizontal_order": [
                "LifeCycleManager.daily_update.num_cow_for_parity_greater_than_3",
                "AnimalManager.daily_updates.num_cows_total"
            ],
            "slice_start": -365
           },
           {
            "name": "Total milk, kg",
            "filters": ["LifeCycleManager.daily_update.daily_milk_production"],
            "vertical_aggregation": "sum",
            "slice_start": -365
           },
           {
            "name": "Milk per cow/d, kg",
            "filters": [
                "LifeCycleManager.daily_update.daily_milk_production",
                "LifeCycleManager.daily_update.milking_cow_num"
            ],
            "horizontal_aggregation": "division",
            "horizontal_order": [
                "LifeCycleManager.daily_update.daily_milk_production",
                "LifeCycleManager.daily_update.milking_cow_num"
            ],
            "horizontal_first": "true",
            "vertical_aggregation": "average",
            "slice_start": -365
           },
           {
            "name": "% milk fat",
            "filters": ["LifeCycleManager.daily_update.herd_milk_fat_percent"],
            "constants": {
                "By 100": 100
            },
            "vertical_aggregation": "average",
            "horizontal_aggregation": "division",
            "slice_start": -365
        },
        {
            "name": "% milk protein",
            "filters": ["LifeCycleManager.daily_update.herd_milk_protein_percent"],
            "constants": {
                "By 100": 100
            },
            "vertical_aggregation": "average",
            "horizontal_aggregation": "division",
            "slice_start": -365
        },
        {
            "name": "Milk fat, kg",
            "cross_references": [
                "Total milk, kg_ver_agg",
                "% milk fat_hor_ver_agg"
            ],
            "horizontal_aggregation": "product"
        },
        {
            "name": "Milk protein, kg",
            "cross_references": [
                "Total milk, kg_ver_agg",
                "% milk protein_hor_ver_agg"
            ],
            "horizontal_aggregation": "product"
        },
        {
            "name": "weighted fat value",
            "cross_references": [
                "Milk fat, kg_hor_agg"
            ],
            "constants": {
                "fat weight": 12.2
            },
            "horizontal_aggregation": "product"
        },
        {
            "name": "weighted protein value",
            "cross_references": [
                "Milk protein, kg_hor_agg"
            ],
            "constants": {
                "protein weight": 7.7
            },
            "horizontal_aggregation": "product"
        },
        {
            "name": "weighted milk value",
            "cross_references": [
                "Total milk, kg_ver_agg"
            ],
            "constants": {
                "milk weight": 0.35
            },
            "horizontal_aggregation": "product"
        },
        {
            "name": "Herd FPCM, kg",
            "cross_references": [
                "weighted fat value_hor_agg",
                "weighted protein value_hor_agg",
                "weighted milk value_hor_agg"
            ],
            "horizontal_aggregation": "sum"
        },
        {
            "name": "Cow FPCM/d, kg",
            "cross_references":[
                "Herd FPCM, kg_hor_agg",
                "Milking cows_ver_agg"
            ],
            "constants": {
                "Days per year": 365
            },
            "horizontal_aggregation": "division",
            "horizontal_order": [
                "Herd FPCM, kg_hor_agg",
                "Milking cows_ver_agg",
                "Days per year"
            ]
        },
           {
            "name": "Calves sold",
            "filters": [
                "LifeCycleManager.daily_update.sold_calf_num"
            ],
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Heifers sold",
            "filters": [
                "LifeCycleManager.daily_update.sold_(heiferII|heiferIII_oversupply)_num"
            ],
            "vertical_aggregation": "sum",
            "horizontal_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Cow herd exits",
            "filters": [
                "LifeCycleManager.daily_update.cow_herd_exit_num"
            ],
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Cow deaths",
            "filters": [
                "LifeCycleManager.daily_update.cull_reason_stats"
                ],
            "variables": "culled for death",
            "vertical_aggregation": "sum",
            "slice_start": -365
           },
        {
            "name": "Cows sold (subtr)",
            "cross_references": [
                "Cow herd exits_ver_agg",
                "Cow deaths_ver_agg"
            ],
            "horizontal_aggregation": "subtraction",
            "horizontal_order": [
                "Cow herd exits_ver_agg",
                "Cow deaths_ver_agg"
            ]
        }, 
        {
            "name": "Cows sold (report)",
            "filters": [
                "AnimalModuleReporter.report_sold_animal_information_sort_by_sell_day.sold_cows_sold_count"
            ],
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
    {
        "name": "Total calf bw sold, kg",
        "filters": [
            "AnimalModuleReporter.report_sold_animal_information_sort_by_sell_day.sold_calves_sold_weight"
        ],
        "vertical_aggregation": "sum",
        "slice_start": -365
    },
    {
        "name": "Avg calf bw sold, kg",
        "cross_references": [
            "Total calf bw sold, kg_ver_agg",
            "Calves sold_ver_agg"
        ],
        "horizontal_aggregation": "division"
    },
        {
            "name": "Total heifer bw sold, kg",
            "filters": [
                "AnimalModuleReporter.report_sold_animal_information_sort_by_sell_day.(heiferII|heiferIII)_sold_weight"
            ],
            "vertical_aggregation": "sum",
            "horizontal_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Avg heifer bw sold, kg",
            "cross_references": [
                "Total heifer bw sold, kg_hor_ver_agg",
                "Heifers sold_hor_ver_agg"
            ],
            "horizontal_aggregation": "division"
        },     
        {
            "name": "Total cow bw sold, kg",
            "filters": [
                "AnimalModuleReporter.report_sold_animal_information_sort_by_sell_day.sold_cows_sold_weight"
            ],
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Avg cow bw sold, kg",
            "cross_references": [
                "Total cow bw sold, kg_ver_agg",
                "Cows sold (subtr)_ver_agg"
            ],
            "horizontal_aggregation": "division"
        },
        {
            "name": "Heifers bought",
            "filters": [
                "LifeCycleManager.daily_update.bought_heifer_num"
            ],
            "vertical_aggregation": "sum",
            "slice_start": -365
           },
           {
            "name": "% herd turnover",
            "cross_references": [
                "Cow herd exits_ver_agg",
                "Total cows_ver_agg"
            ],
            "horizontal_aggregation": "division"
           },
           {
            "name": "Average age at first calving",
            "filters": [
                "LifeCycleManager.daily_update.avg_age_for_calving_1"
            ],
            "vertical_aggregation": "average",
            "slice_start": -365
        },
        {
            "name": "Lact cow DMI, kg",
            "filters": [
                "^AnimalModuleReporter.*LAC_COW*"
            ],
            "variables": "dry_matter_intake_total",
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Total herd DMI, kg",
            "filters": [
                "^AnimalModuleReporter.report_daily_ration.*"
            ],
            "variables": "dry_matter_intake_total",
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Lact cow DMI/cow/d, kg",
            "cross_references": [
                "Lact cow DMI, kg_ver_agg",
                "Milking cows_ver_agg"
            ],
            "constants": {
                "Days per year": 365
            },
            "horizontal_aggregation": "division",
            "horizontal_order": [
                "Lact cow DMI, kg_ver_agg",
                "Milking cows_ver_agg",
                "Days per year"
            ]
        },
        {
            "name": "Calving interval",
            "filters": [
                "LifeCycleManager.daily_update.avg_calving_interval"
            ],
            "vertical_aggregation": "average", 
            "slice_start": -365
        },
        {
            "name": "Calf enteric methane, g",
            "filters": [
                "AnimalManager.daily_updates.daily_aggregate_calf_enteric_methane_g"
            ],
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Heifer enteric methane, g",
            "filters": [
                "AnimalManager.daily_updates.daily_aggregate_heifer_enteric_methane_g"
            ],
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Dry cow enteric methane, g",
            "filters": [
                "AnimalManager.daily_updates.daily_aggregate_dry_cow_enteric_methane_g"
            ],
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Lact cow enteric methane, g",
            "filters": [
                "AnimalManager.daily_updates.daily_aggregate_lactating_cow_enteric_methane_g"
            ],
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Total enteric methane, g",
            "filters": [
                "AnimalManager.daily_updates.daily_aggregate_(calf|heifer|dry_cow|lactating_cow)_enteric_methane_g"
            ],
            "vertical_aggregation": "sum",
            "horizontal_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Lact cow purchased feed emissions, kg",
            "filters": [
                "^AnimalModuleReporter.*LAC_COW*"
            ],
            "variables": "feed_emissions_total",
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Total purchased feed emissions, kg",
            "filters": [
                "AnimalModuleReporter.report_daily_feed_emissions.*"
            ],
            "variables": "feed_emissions_total",
            "vertical_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Total housing methane, kg",
            "filters": [
                "ManureHandlerDailyOutput_Pen_.*housing_methane"
            ],
            "vertical_aggregation": "sum",
            "horizontal_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Total housing ammonia, kg",
            "filters": [
                "ManureHandlerDailyOutput_Pen_.*housing_ammonia"
            ],
            "vertical_aggregation": "sum",
            "horizontal_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Total storage methane, kg",
            "filters": [
                "ManureTreatmentDailyOutput_Pen_.*storage_methane"
            ],
            "vertical_aggregation": "sum",
            "horizontal_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Total storage ammonia, kg",
            "filters": [
                "ManureTreatmentDailyOutput_Pen_.*storage_ammonia"
            ],
            "vertical_aggregation": "sum",
            "horizontal_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Total storage nitrous oxide, kg",
            "filters": [
                "ManureTreatmentDailyOutput_Pen_.*storage_nitrous_oxide.*"
            ],
            "vertical_aggregation": "sum",
            "horizontal_aggregation": "sum",
            "slice_start": -365
        },
        {
            "name": "Total storage biogas, kg",
            "filters": [
                "ManureTreatmentDailyOutput_Pen_.*biogas$"
            ],
            "vertical_aggregation": "sum",
            "horizontal_aggregation": "sum",
            "slice_start": -365
        }
        
   ]
}