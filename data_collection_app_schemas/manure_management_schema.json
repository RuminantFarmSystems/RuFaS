            "enum": [
              "slurry storage underfloor",
              "slurry storage outdoor",
              "open lots",
              "compost bedded pack barn",
              "anaerobic lagoon",
              "anaerobic digestion and lagoon",
              "anaerobic digestion and lagoon with separator"
